{
  "name": "mahesh-multiverse",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspace=client",
    "build:prerender": "npm run build --workspace=client && node scripts/prerender.mjs",
    "build:resume": "node scripts/build-resume.mjs ../jobsearch/resume-ai-version.md client/public/mahesh-inder-resume.pdf",
    "start": "npm run start --workspace=server",
    "test:e2e": "npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.1.0",
    "playwright": "^1.59.1"
  },
  "dependencies": {
    "groq-sdk": "^1.1.2"
  }
}
