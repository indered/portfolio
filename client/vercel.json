{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/resume", "destination": "/mahesh-inder-resume.pdf" },
    { "source": "/resume/download", "destination": "/mahesh-inder-resume.pdf" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/resume",
      "headers": [
        { "key": "Content-Disposition", "value": "inline; filename=\"Mahesh_Inder_Full_Stack_AI.pdf\"" }
      ]
    },
    {
      "source": "/resume/download",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=\"Mahesh_Inder_Full_Stack_AI.pdf\"" }
      ]
    }
  ]
}
